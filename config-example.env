# ------------------------------------------------------------
# Tuma250 Site Credentials
# ------------------------------------------------------------
TUMA250_BASE_URL=https://tuma250.com
TUMA250_USERNAME=your-email@example.com
TUMA250_PASSWORD=your-password

# Path to persist the Playwright browser session (cookies/storage).
# Relative to the project root.
TUMA250_SESSION_FILE=.tuma250_session.json

# Set to "true" to run Playwright in headed mode for debugging.
TUMA250_DEBUG=false
